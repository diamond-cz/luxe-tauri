{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LUXE",
  "version": "0.1.0",
  "identifier": "io.luxe.tauri",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "LUXE",
        "width": 1300,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 380,
        "center": true,
        "resizable": true,
        "decorations": false,
        "transparent": false,
        "shadow": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ],
    "resources": [
      "resources/translations/*.json"
    ]
  }
}
